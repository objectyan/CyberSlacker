<Window x:Class="CyberSlacker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
        Title="打工人小组件"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="False" 
         WindowStartupLocation="Manual" 
        Left="100" 
        Top="100" 
        Height="300" 
        Width="300">

    <Grid Background="#01000000" MouseLeftButtonDown="Window_MouseLeftButtonDown" Margin="0,0,0,0">
        <!-- 系统托盘图标 -->
        <tb:TaskbarIcon x:Name="MyNotifyIcon"  ToolTipText="{Binding TaskbarTooltip}" Margin="0,0,0,36">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="设置信息" Click="OpenSettings_Click">
                        <MenuItem.Icon>
                            <Viewbox Width="16" Height="16">
                                <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.97 19.05,5.05L16.56,6.05C16.04,5.66 15.47,5.34 14.86,5.12L14.47,2.47C14.44,2.23 14.24,2.05 14,2.05H10C9.76,2.05 9.56,2.23 9.53,2.47L9.14,5.12C8.53,5.34 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.97 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.95C7.96,18.34 8.53,18.66 9.14,18.88L9.53,21.53C9.56,21.77 9.76,21.95 10,21.95H14C14.24,21.95 14.44,21.77 14.47,21.53L14.86,18.88C15.47,18.66 16.04,18.34 16.56,17.95L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" 
                          Fill="#FFD700" Stretch="Uniform"/>
                            </Viewbox>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="关于软件" Click="OnOpenAbout">
                        <MenuItem.Icon>
                            <Viewbox Width="16" Height="16">
                                <Path Data="M11,9H13V7H11V9M11,17H13V11H11V17M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2Z" 
                          Fill="#00E5FF" Stretch="Uniform"/>
                            </Viewbox>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="退出程序" Click="ExitApp_Click">
                        <MenuItem.Icon>
                            <Viewbox Width="14" Height="14">
                                <Path Data="M12,2V12M7.5,6.5A9,9 0 1,0 16.5,6.5" 
                          Stroke="#FF5252" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Fill="Transparent"/>
                            </Viewbox>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- 主体视觉部分 -->
        <Border Background="#CC111111" CornerRadius="20" BorderBrush="#33FFFFFF" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="Black" Opacity="0.5"/>
            </Border.Effect>

            <StackPanel Margin="20">
                <!-- 顶部节日/状态提示 -->
                <Border Background="#22FFFFFF" Padding="12,8" CornerRadius="8" Margin="0,0,0,15" MinHeight="50">
                    <TextBlock Text="{Binding HolidayTip}" 
                               Foreground="White" 
                               FontSize="13" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"
                               TextWrapping="Wrap" 
                               TextAlignment="Center" 
                               LineHeight="20"/>
                </Border>

                <!-- 下班倒计时 -->
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="距离下班还有" Foreground="#888" FontSize="11"/>
                    <TextBlock Text="{Binding OffWorkCountdown}" Foreground="#FF5252" FontSize="36" FontWeight="Bold"/>
                </StackPanel>

                <!-- 周末/节假日混合显示 -->
                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="距离周末还有" Foreground="#888" FontSize="11"/>
                    <TextBlock Text="{Binding WeekendCountdown}" Foreground="White" FontSize="15"/>
                </StackPanel>

                <!-- 发薪日 -->
                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="距离发薪日还有" Foreground="#888" FontSize="11"/>
                    <TextBlock Text="{Binding PayDayCountdown}" Foreground="Gold" FontSize="15" FontWeight="Bold"/>
                </StackPanel>

                <!-- 下一个节日 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="下一个节日 " Foreground="#888" FontSize="11"/>
                    <TextBlock Text="{Binding NextHolidayName}" Foreground="LimeGreen" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="{Binding NextHolidayCountdown}" Foreground="White" FontSize="14"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>