<Window x:Class="CyberSlacker.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于赛博摸鱼员" Height="400" Width="350" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F9F9F9" FontFamily="Microsoft YaHei">
    <Grid>
        <StackPanel Margin="30" VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- 1. Logo (这里可以直接引用你的 app.ico) -->
            <Image Source="/CyberSlacker;component/app.ico" Width="64" Height="64" Margin="0,0,0,15"/>

            <!-- 2. 标题与版本 -->
            <TextBlock Text="赛博摸鱼员" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#333"/>
            <TextBlock x:Name="VersionText" Text="Version 1.0.0" FontSize="12" HorizontalAlignment="Center" Foreground="#888" Margin="0,5,0,20"/>

            <!-- 3. 宣言 -->
            <Border Background="#E1F5FE" Padding="15,10" CornerRadius="8" Margin="0,0,0,25">
                <TextBlock Text="“钱是老板的，命是自己的”" FontStyle="Italic" Foreground="#0288D1" HorizontalAlignment="Center"/>
            </Border>

            <!-- 4. 链接区域 -->
            <StackPanel>
                <TextBlock HorizontalAlignment="Center">
                    官方主页：<Hyperlink NavigateUri="https://github.com/objectyan/CyberSlacker" RequestNavigate="OnNavigate">GitHub 仓库</Hyperlink>
                </TextBlock>
                <TextBlock HorizontalAlignment="Center">
                    反馈建议：<Hyperlink NavigateUri="https://github.com/objectyan/CyberSlacker/issues" RequestNavigate="OnNavigate">提交 Issue</Hyperlink>
                </TextBlock>
                <TextBlock HorizontalAlignment="Center">
                    法律协议：<Hyperlink NavigateUri="https://github.com/objectyan/CyberSlacker/blob/master/LICENSE" RequestNavigate="OnNavigate">开源协议 (MIT)</Hyperlink>
                </TextBlock>
            </StackPanel>

            <Button x:Name="updateBtn" Content="检查更新" 
                    Click="OnCheckUpdate"
                    Margin="0,20,0,0"
                    Padding="20,5"
                    Background="#2196F3" 
                    Foreground="White" 
                    FontWeight="Bold"
                    Cursor="Hand">      
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="15"/>
                        <!-- 圆角按钮 -->
                    </Style>
                </Button.Resources>
            </Button>

            <!-- 5. 底部版权 -->
            <TextBlock Text="Copyright © 2026 objectyan" FontSize="10" Foreground="#AAA" HorizontalAlignment="Center" Margin="0,30,0,0"/>
        </StackPanel>
    </Grid>
</Window>